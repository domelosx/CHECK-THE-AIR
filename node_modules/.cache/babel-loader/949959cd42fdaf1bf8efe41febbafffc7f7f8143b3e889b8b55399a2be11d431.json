{"ast":null,"code":"import{useEffect,useState}from\"react\";import{loadSettings}from\"@/lib/settings\";export function useSettings(){const[settings,setSettings]=useState(loadSettings());useEffect(()=>{const onChange=()=>setSettings(loadSettings());window.addEventListener(\"scba-settings-change\",onChange);window.addEventListener(\"storage\",onChange);return()=>{window.removeEventListener(\"scba-settings-change\",onChange);window.removeEventListener(\"storage\",onChange);};},[]);return settings;}","map":{"version":3,"names":["useEffect","useState","loadSettings","useSettings","settings","setSettings","onChange","window","addEventListener","removeEventListener"],"sources":["C:/Users/domel/Downloads/check-the-air-source/frontend/src/hooks/useSettings.js"],"sourcesContent":["import { useEffect, useState } from \"react\";\nimport { loadSettings } from \"@/lib/settings\";\n\nexport function useSettings() {\n    const [settings, setSettings] = useState(loadSettings());\n    useEffect(() => {\n        const onChange = () => setSettings(loadSettings());\n        window.addEventListener(\"scba-settings-change\", onChange);\n        window.addEventListener(\"storage\", onChange);\n        return () => {\n            window.removeEventListener(\"scba-settings-change\", onChange);\n            window.removeEventListener(\"storage\", onChange);\n        };\n    }, []);\n    return settings;\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,QAAQ,KAAQ,OAAO,CAC3C,OAASC,YAAY,KAAQ,gBAAgB,CAE7C,MAAO,SAAS,CAAAC,WAAWA,CAAA,CAAG,CAC1B,KAAM,CAACC,QAAQ,CAAEC,WAAW,CAAC,CAAGJ,QAAQ,CAACC,YAAY,CAAC,CAAC,CAAC,CACxDF,SAAS,CAAC,IAAM,CACZ,KAAM,CAAAM,QAAQ,CAAGA,CAAA,GAAMD,WAAW,CAACH,YAAY,CAAC,CAAC,CAAC,CAClDK,MAAM,CAACC,gBAAgB,CAAC,sBAAsB,CAAEF,QAAQ,CAAC,CACzDC,MAAM,CAACC,gBAAgB,CAAC,SAAS,CAAEF,QAAQ,CAAC,CAC5C,MAAO,IAAM,CACTC,MAAM,CAACE,mBAAmB,CAAC,sBAAsB,CAAEH,QAAQ,CAAC,CAC5DC,MAAM,CAACE,mBAAmB,CAAC,SAAS,CAAEH,QAAQ,CAAC,CACnD,CAAC,CACL,CAAC,CAAE,EAAE,CAAC,CACN,MAAO,CAAAF,QAAQ,CACnB","ignoreList":[]},"metada